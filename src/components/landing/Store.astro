---
const products = [
  {
    name: "Atlas Kit",
    price: "$99",
    description: "A complete Astro & Tailwind UI kit for building modern marketing sites fast.",
    tags: ["astro", "tailwind"],
  },
  {
    name: "Nebula Dark",
    price: "$99",
    description: "Dark-mode first template with stunning visuals and smooth interactions.",
    tags: ["dark", "design"],
  },
  {
    name: "Mono Portfolio",
    price: "$99",
    description: "Minimal monochrome portfolio template for designers and developers.",
    tags: ["portfolio", "minimal"],
  },
];
---

<section class="py-12 border-t border-base-100" id="store">
  <div class="px-6 max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-base font-semibold text-base-900">Our latest templates</h2>
      <a
        href="#_"
        class="text-xs text-base-500 hover:text-base-900 transition-colors"
      >
        View store &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        products.map((product) => (
          <a
            href="#_"
            class="group block bg-white rounded-2xl border border-base-100 hover:border-base-300 hover:shadow-sm transition-all duration-200 p-5"
          >
            <div class="aspect-video bg-base-50 rounded-xl mb-4 flex items-center justify-center">
              <span class="text-2xl font-semibold text-base-300 tracking-tight">
                {product.name.charAt(0)}
              </span>
            </div>
            <div class="flex items-start justify-between gap-2">
              <div>
                <h3 class="text-sm font-medium text-base-900">{product.name}</h3>
                <p class="mt-1 text-xs text-base-500 leading-relaxed">
                  {product.description}
                </p>
                <div class="flex gap-1 mt-3">
                  {product.tags.map((tag) => (
                    <span class="text-xs text-base-400 bg-base-50 px-2 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <span class="shrink-0 text-sm font-semibold text-base-900">
                {product.price}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
