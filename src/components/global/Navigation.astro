---
const b = import.meta.env.BASE_URL; // e.g. "/sc/"
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  const full = path === '/' ? b : `${b}${path}`.replace(/\/+/g, '/');
  if (path === '/') return currentPath === b || currentPath === b.replace(/\/$/, '');
  return currentPath.startsWith(full);
};
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="px-4 mx-auto max-w-7xl flex items-center justify-between h-14">
    <!-- Logo -->
    <a href={b} class="text-xl font-bold text-[#7a00df] tracking-tight flex-shrink-0">
      SCO
      <span class="text-xs font-normal text-[#666666] ml-1 hidden sm:inline">Supreme Court Observer</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-0.5">
      <a href={`${b}cases/`} class={`text-sm px-3 py-2 rounded-md transition-colors duration-150 ${isActive('/cases/') ? 'text-[#7a00df] font-medium' : 'text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50'}`}>
        Cases
      </a>
      <a href={`${b}judges/`} class={`text-sm px-3 py-2 rounded-md transition-colors duration-150 ${isActive('/judges/') ? 'text-[#7a00df] font-medium' : 'text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50'}`}>
        Judges
      </a>
      <a href={`${b}analysis/`} class={`text-sm px-3 py-2 rounded-md transition-colors duration-150 ${isActive('/analysis/') ? 'text-[#7a00df] font-medium' : 'text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50'}`}>
        Analysis
      </a>
      <a href={`${b}glossary/`} class={`text-sm px-3 py-2 rounded-md transition-colors duration-150 ${isActive('/glossary/') ? 'text-[#7a00df] font-medium' : 'text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50'}`}>
        Glossary
      </a>

      <!-- About SC dropdown -->
      <div class="relative group">
        <button class="text-sm px-3 py-2 rounded-md text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50 transition-colors duration-150 flex items-center gap-1">
          About SC
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-0 mt-1 w-44 bg-white border border-gray-200 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
          <a href={`${b}about/`} class="block px-4 py-2.5 text-sm text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50 rounded-t-lg">About Us</a>
          <a href={`${b}glossary/`} class="block px-4 py-2.5 text-sm text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50 rounded-b-lg">Glossary</a>
        </div>
      </div>
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <!-- Search -->
      <button aria-label="Search" class="hidden sm:flex p-2 rounded-md text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50 transition-colors duration-150">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Subscribe -->
      <a href={`${b}about/`} class="inline-flex items-center text-xs font-semibold bg-[#7a00df] text-white px-4 py-2 rounded-full hover:bg-[#6600c0] transition-colors duration-150">
        Subscribe
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2 rounded-md text-[#666666] hover:text-[#1a1a1a] hover:bg-gray-50"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 bg-white">
    <nav class="px-4 py-3 flex flex-col gap-1">
      <a href={`${b}cases/`} class={`text-sm py-2.5 px-3 rounded-md ${isActive('/cases/') ? 'text-[#7a00df] font-medium bg-[#f5e6ff]' : 'text-[#666666] hover:text-[#1a1a1a]'}`}>Cases</a>
      <a href={`${b}judges/`} class={`text-sm py-2.5 px-3 rounded-md ${isActive('/judges/') ? 'text-[#7a00df] font-medium bg-[#f5e6ff]' : 'text-[#666666] hover:text-[#1a1a1a]'}`}>Judges</a>
      <a href={`${b}analysis/`} class={`text-sm py-2.5 px-3 rounded-md ${isActive('/analysis/') ? 'text-[#7a00df] font-medium bg-[#f5e6ff]' : 'text-[#666666] hover:text-[#1a1a1a]'}`}>Analysis</a>
      <a href={`${b}glossary/`} class={`text-sm py-2.5 px-3 rounded-md ${isActive('/glossary/') ? 'text-[#7a00df] font-medium bg-[#f5e6ff]' : 'text-[#666666] hover:text-[#1a1a1a]'}`}>Glossary</a>
      <a href={`${b}about/`} class={`text-sm py-2.5 px-3 rounded-md ${isActive('/about/') ? 'text-[#7a00df] font-medium bg-[#f5e6ff]' : 'text-[#666666] hover:text-[#1a1a1a]'}`}>About</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
