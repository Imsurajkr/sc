---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<div class="border-b border-gray-200 pb-6 mb-8">
  <h1 class="text-3xl font-bold text-[#1a1a1a] tracking-tight">{title}</h1>
  {description && (
    <p class="mt-2 text-base text-[#666666] max-w-2xl">{description}</p>
  )}
</div>
