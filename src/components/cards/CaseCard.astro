---
import type { CollectionEntry } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  case: CollectionEntry<'cases'>;
}

const { case: caseEntry } = Astro.props;
const { title, status, petitioner, respondent, description, tags, nextHearing, decidedDate, filedDate } = caseEntry.data;
const slug = caseEntry.slug;
const b = import.meta.env.BASE_URL;

const statusVariant = status === 'decided' ? 'green' : 'amber';
const statusLabel = status === 'decided' ? 'Decided' : 'Pending';

const dateDisplay = status === 'decided' && decidedDate
  ? `Decided ${decidedDate}`
  : nextHearing
  ? `Hearing: ${nextHearing}`
  : `Filed: ${filedDate}`;
---

<article
  class="group bg-white rounded-xl border border-gray-100 hover:border-[#7a00df]/30 hover:shadow-lg transition-all duration-300 flex overflow-hidden"
  data-status={status}
  data-tags={tags.join(',')}
  data-title={title.toLowerCase()}
>
  <!-- Left accent bar -->
  <div class={`w-1 flex-shrink-0 ${status === 'pending' ? 'bg-amber-400' : 'bg-emerald-500'}`}></div>

  <div class="p-5 flex flex-col gap-3 flex-1">
    <div class="flex items-center justify-between gap-2">
      <Badge label={statusLabel} variant={statusVariant} />
      <span class="text-xs text-[#999]">{dateDisplay}</span>
    </div>

    <div>
      <h3 class="font-serif text-lg font-bold text-[#1a1a1a] leading-snug group-hover:text-[#7a00df] transition-colors">
        <a href={`${b}cases/${slug}/`}>{title}</a>
      </h3>
      <p class="text-sm text-[#888] mt-1 italic">
        {petitioner} <span class="not-italic font-semibold text-[#444]">v.</span> {respondent}
      </p>
    </div>

    <p class="text-sm text-[#555] line-clamp-2 leading-relaxed">{description}</p>

    <div class="flex flex-wrap gap-1.5 pt-2 border-t border-gray-100">
      {tags.slice(0, 3).map((tag) => (
        <a
          href={`${b}cases/?tag=${tag}`}
          class="text-xs text-[#7a00df] bg-[#f5e6ff] hover:bg-[#ead0ff] px-2.5 py-1 rounded-full transition-colors"
        >
          #{tag}
        </a>
      ))}
    </div>
  </div>
</article>
