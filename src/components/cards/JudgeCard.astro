---
import type { CollectionEntry } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  judge: CollectionEntry<'judges'>;
}

const { judge } = Astro.props;
const { name, designation, status, appointedDate, retirementDate, pendingCases, judgments, initials } = judge.data;
const slug = judge.id.replace(/\.json$/, '');
const b = import.meta.env.BASE_URL;

const statusVariant = status === 'sitting' ? 'green' : 'gray';
const statusLabel = status === 'sitting' ? 'Sitting' : 'Retired';

const avatarColors = [
  { bg: '#7a00df', text: '#fff' },
  { bg: '#1d4ed8', text: '#fff' },
  { bg: '#0f766e', text: '#fff' },
  { bg: '#b45309', text: '#fff' },
  { bg: '#be185d', text: '#fff' },
];
const color = avatarColors[name.charCodeAt(8 % name.length) % avatarColors.length];

const termDisplay = retirementDate
  ? `${appointedDate} – ${retirementDate}`
  : `Appointed ${appointedDate}`;
---

<article class="group bg-white rounded-xl border border-gray-100 hover:border-[#7a00df]/30 hover:shadow-lg transition-all duration-300 overflow-hidden">
  <!-- Top color strip + avatar -->
  <div class="relative h-16" style={`background: ${color.bg}15`}>
    <div class="absolute -bottom-7 left-5">
      <a href={`${b}judges/${slug}/`}>
        <div
          class="w-14 h-14 rounded-full flex items-center justify-center text-lg font-bold"
          style={`background: ${color.bg}; color: ${color.text}; border: 3px solid white;`}
        >
          {initials}
        </div>
      </a>
    </div>
    <div class="absolute top-3 right-4">
      <Badge label={statusLabel} variant={statusVariant} />
    </div>
  </div>

  <div class="pt-9 px-5 pb-5">
    <h3 class="font-serif font-bold text-[#1a1a1a] leading-tight group-hover:text-[#7a00df] transition-colors">
      <a href={`${b}judges/${slug}/`}>{name}</a>
    </h3>
    <p class="text-xs text-[#888] mt-0.5 leading-snug">{designation}</p>
    <p class="text-xs text-[#aaa] mt-2">{termDisplay}</p>

    <div class="flex gap-4 mt-4 pt-4 border-t border-gray-100">
      <div>
        <div class="text-lg font-bold text-[#1a1a1a]">{judgments}</div>
        <div class="text-xs text-[#999]">Judgments</div>
      </div>
      {status === 'sitting' && (
        <div>
          <div class="text-lg font-bold text-[#1a1a1a]">{pendingCases}</div>
          <div class="text-xs text-[#999]">Pending</div>
        </div>
      )}
    </div>
  </div>
</article>
