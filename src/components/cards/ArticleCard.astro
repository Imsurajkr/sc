---
import type { CollectionEntry } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  article: CollectionEntry<'articles'>;
  variant?: 'featured' | 'compact';
}

const { article, variant = 'featured' } = Astro.props;
const { title, category, author, date, excerpt } = article.data;
const slug = article.slug;

const formattedDate = new Date(date).toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

{variant === 'featured' ? (
  <article class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-200 flex flex-col">
    <!-- Gradient cover area -->
    <div class="h-36 bg-gradient-to-br from-[#7a00df] to-[#5200a0] flex items-end p-4">
      <Badge label={category} variant="purple" />
    </div>
    <div class="p-5 flex flex-col gap-2 flex-1">
      <h3 class="font-serif text-xl font-bold text-[#1a1a1a] leading-snug hover:text-[#7a00df] transition-colors">
        <a href={`/analysis/${slug}/`}>{title}</a>
      </h3>
      <p class="text-sm text-[#666666] line-clamp-3">{excerpt}</p>
      <div class="flex items-center gap-2 mt-auto pt-3 border-t border-gray-100">
        <span class="text-xs font-medium text-[#1a1a1a]">{author}</span>
        <span class="text-xs text-[#666666]">·</span>
        <span class="text-xs text-[#666666]">{formattedDate}</span>
      </div>
    </div>
  </article>
) : (
  <article class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow duration-200 flex gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <Badge label={category} variant="purple" />
        <span class="text-xs text-[#666666]">{formattedDate}</span>
      </div>
      <h3 class="font-semibold text-[#1a1a1a] text-base leading-snug hover:text-[#7a00df] transition-colors">
        <a href={`/analysis/${slug}/`}>{title}</a>
      </h3>
      <p class="text-sm text-[#666666] mt-1 line-clamp-2">{excerpt}</p>
      <p class="text-xs text-[#666666] mt-2">By <span class="font-medium text-[#1a1a1a]">{author}</span></p>
    </div>
    <div class="w-20 h-20 bg-gradient-to-br from-[#7a00df] to-[#5200a0] rounded-md flex-shrink-0 flex items-center justify-center text-white text-2xl font-bold">
      {title.charAt(0)}
    </div>
  </article>
)}
