---
import type { CollectionEntry } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  article: CollectionEntry<'articles'>;
  variant?: 'featured' | 'compact' | 'hero';
}

const { article, variant = 'featured' } = Astro.props;
const { title, category, author, date, excerpt, coverImage } = article.data;
const slug = article.slug;
const b = import.meta.env.BASE_URL;

const formattedDate = new Date(date).toLocaleDateString('en-IN', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const fallbackGradient = 'linear-gradient(135deg, #7a00df 0%, #3d0075 100%)';
---

{variant === 'featured' ? (
  <article class="group bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-gray-200 hover:shadow-lg transition-all duration-300 flex flex-col">
    <a href={`${b}analysis/${slug}/`} class="block overflow-hidden h-52 bg-gray-100">
      {coverImage ? (
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full" style={`background: ${fallbackGradient}`}></div>
      )}
    </a>
    <div class="p-5 flex flex-col gap-3 flex-1">
      <div class="flex items-center gap-2">
        <Badge label={category} variant="purple" />
      </div>
      <h3 class="font-serif text-xl font-bold text-[#1a1a1a] leading-snug group-hover:text-[#7a00df] transition-colors line-clamp-2">
        <a href={`${b}analysis/${slug}/`}>{title}</a>
      </h3>
      <p class="text-sm text-[#666666] line-clamp-2 leading-relaxed">{excerpt}</p>
      <div class="flex items-center gap-2 mt-auto pt-3 border-t border-gray-100 text-xs text-[#666666]">
        <span class="font-medium text-[#1a1a1a]">{author}</span>
        <span>·</span>
        <span>{formattedDate}</span>
      </div>
    </div>
  </article>
) : (
  <article class="group bg-white rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all duration-300 overflow-hidden flex gap-0">
    <div class="flex-1 p-4 flex flex-col justify-between min-w-0">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <Badge label={category} variant="purple" />
          <span class="text-xs text-[#999]">{formattedDate}</span>
        </div>
        <h3 class="font-serif font-bold text-[#1a1a1a] text-base leading-snug group-hover:text-[#7a00df] transition-colors line-clamp-2">
          <a href={`${b}analysis/${slug}/`}>{title}</a>
        </h3>
        <p class="text-sm text-[#666666] mt-1 line-clamp-2 leading-relaxed">{excerpt}</p>
      </div>
      <p class="text-xs text-[#999] mt-3">By <span class="font-medium text-[#555]">{author}</span></p>
    </div>
    <a href={`${b}analysis/${slug}/`} class="w-28 sm:w-36 flex-shrink-0 overflow-hidden bg-gray-100">
      {coverImage ? (
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-3xl font-bold text-white" style={`background: ${fallbackGradient}`}>
          {title.charAt(0)}
        </div>
      )}
    </a>
  </article>
)}
