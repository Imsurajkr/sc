---
import BaseHead from "@/components/BaseHead.astro";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Supreme Court Observer",
  description = "Independent reporting, analysis, and data on the Supreme Court of India.",
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="bg-white text-[#1a1a1a] font-sans min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
