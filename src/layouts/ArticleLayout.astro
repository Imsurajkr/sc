---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Badge from "@/components/ui/Badge.astro";

interface Props {
  title: string;
  description?: string;
  category?: string;
  author?: string;
  date?: string;
  tags?: string[];
}

const { title, description, category, author, date, tags = [] } = Astro.props;
const b = import.meta.env.BASE_URL;

const formattedDate = date
  ? new Date(date).toLocaleDateString('en-IN', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : '';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <!-- Article header -->
    <header class="mb-8">
      {category && (
        <div class="mb-3">
          <Badge label={category} variant="purple" />
        </div>
      )}
      <h1 class="font-serif text-3xl md:text-4xl font-bold text-[#1a1a1a] leading-tight mb-4">
        {title}
      </h1>
      {(author || date) && (
        <div class="flex items-center gap-3 text-sm text-[#666666]">
          {author && <span>By <span class="font-medium text-[#1a1a1a]">{author}</span></span>}
          {author && date && <span>·</span>}
          {date && <span>{formattedDate}</span>}
        </div>
      )}
    </header>

    <!-- Gradient cover image -->
    <div class="w-full h-48 rounded-lg bg-gradient-to-br from-[#7a00df] to-[#5200a0] mb-8"></div>

    <!-- Article body -->
    <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-[#1a1a1a] prose-p:text-[#333333] prose-p:leading-relaxed prose-a:text-[#7a00df] prose-a:no-underline hover:prose-a:underline">
      <slot />
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-gray-200">
        <p class="text-xs text-[#666666] font-medium mb-2">Tags</p>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a href={`${b}analysis/?tag=${tag}`} class="text-xs text-[#7a00df] bg-[#f5e6ff] px-3 py-1 rounded-full hover:bg-[#ead0ff] transition-colors">
              #{tag}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
